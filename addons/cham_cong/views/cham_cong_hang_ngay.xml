<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cham_cong_hang_ngay_tree" model="ir.ui.view">
        <field name="name">cham_cong_hang_ngay.tree</field>
        <field name="model">cham_cong_hang_ngay</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="nhan_vien_id"/>
                <field name="ngay"/>
                <field name="gio_check_in" widget="float_time"/>
                <field name="gio_check_out" widget="float_time"/>
                <field name="phut_di_muon" decoration-danger="phut_di_muon &gt; 0"/>
                <field name="phut_ve_som" decoration-danger="phut_ve_som &gt; 0"/>
                <field name="trang_thai" widget="badge" 
                       decoration-success="trang_thai == 'di_lam'" 
                       decoration-warning="trang_thai == 'nua_ngay'" 
                       decoration-info="trang_thai == 'nghi_co_luong'" 
                       decoration-danger="trang_thai == 'nghi_khong_luong'" 
                       decoration-muted="trang_thai == 'vang_mat'"/>
                <field name="so_gio_ot" sum="Tổng giờ làm thêm"/>
                <field name="ghi_chu"/>
            </tree>
        </field>
    </record>

    <record id="view_cham_cong_hang_ngay_search" model="ir.ui.view">
        <field name="name">cham_cong_hang_ngay.search</field>
        <field name="model">cham_cong_hang_ngay</field>
        <field name="arch" type="xml">
            <search>
                <field name="nhan_vien_id"/>
                <field name="ngay"/>
            </search>
        </field>
    </record>

    <record id="action_cham_cong_hang_ngay" model="ir.actions.act_window">
        <field name="name">Chấm công hàng ngày</field>
        <field name="res_model">cham_cong_hang_ngay</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_cham_cong_hang_ngay_search"/>
    </record>
</odoo>
