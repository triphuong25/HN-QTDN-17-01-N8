<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_phieu_luong_tree" model="ir.ui.view">
        <field name="name">phieu_luong.tree</field>
        <field name="model">phieu_luong</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'paid'">
                <field name="display_name"/>
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="luong_thuc_te" sum="Tổng lương thực tế"/>
                <field name="luong_ot" sum="Tổng lương OT"/>
                <field name="tong_khau_tru" sum="Tổng khấu trừ"/>
                <field name="thuc_linh" sum="Tổng thực lĩnh"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'approved'"
                       decoration-success="state == 'paid'"/>
            </tree>
        </field>
    </record>

    <record id="view_phieu_luong_form" model="ir.ui.view">
        <field name="name">phieu_luong.form</field>
        <field name="model">phieu_luong</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Phê duyệt" type="object" class="oe_highlight" states="draft"/>
                    <button name="action_pay" string="Thanh toán" type="object" class="oe_highlight" states="approved"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin chung">
                            <field name="nhan_vien_id"/>
                            <field name="thang"/>
                            <field name="nam"/>
                        </group>
                        <group string="Thông tin công">
                            <field name="ngay_cong_chuan"/>
                            <field name="ngay_cong_thuc_te"/>
                            <field name="so_gio_ot"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết lương">
                            <group col="2">
                                <group string="Khoản nhận">
                                    <field name="luong_co_ban"/>
                                    <field name="luong_thuc_te"/>
                                    <field name="luong_ot"/>
                                    <field name="phu_cap"/>
                                </group>
                                <group string="Khấu trừ bảo hiểm">
                                    <field name="muc_dong_bao_hiem"/>
                                    <field name="tien_bhxh"/>
                                    <field name="tien_bhyt"/>
                                    <field name="tien_bhtn"/>
                                    <field name="tong_khau_tru" style="font-weight: bold;"/>
                                </group>
                                <group string="Thuế &amp; Giảm trừ gia cảnh">
                                    <field name="giam_tru_ban_than"/>
                                    <field name="so_nguoi_phu_thuoc"/>
                                    <field name="giam_tru_phu_thuoc"/>
                                    <field name="thu_nhap_chiu_thue"/>
                                    <field name="thue_tncn" style="font-weight: bold; color: red;"/>
                                </group>
                            </group>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="thuc_linh" class="oe_subtotal_footer_separator" style="font-size: 1.5em; font-weight: bold;"/>
                            </group>
                        </page>
                        <page string="Bảng chi tiết dòng lương">
                            <field name="line_ids" readonly="1">
                                <tree decoration-success="type == 'thu_nhap'" decoration-danger="type == 'khau_tru'">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="amount" sum="Tổng cộng"/>
                                    <field name="type" widget="badge"
                                           decoration-success="type == 'thu_nhap'"
                                           decoration-danger="type == 'khau_tru'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_phieu_luong_kanban" model="ir.ui.view">
        <field name="name">phieu_luong.kanban</field>
        <field name="model">phieu_luong</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="display_name"/>
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="thuc_linh"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title" style="font-size: 1.1em; color: #1e3a8a;">
                                    <field name="display_name"/>
                                </strong>
                                <div style="margin-top: 5px; color: #475569;">
                                    <strong>Nhân viên:</strong> <field name="nhan_vien_id"/>
                                </div>
                                <div style="color: #475569;">
                                    <strong>Thời gian:</strong> Tháng <field name="thang"/>/<field name="nam"/>
                                </div>
                                <div style="margin-top: 5px; font-weight: bold; color: #059669; font-size: 1.1em;">
                                    <strong>Thực lĩnh:</strong> <field name="thuc_linh"/> VND
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu lương nhân viên</field>
        <field name="res_model">phieu_luong</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
