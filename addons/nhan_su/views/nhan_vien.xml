<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_contracts" type="object" class="oe_stat_button" icon="fa-file-text-o">
                                <field name="contract_count" string="Hợp đồng" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_read_only" style="font-size:25px; margin-top: 10px;">Nhân viên</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ho_ten_dem"/>
                            <field name="ten"/>
                            <field name="ho_va_ten"/>
                            <field name="ma_dinh_danh"/>
                            <field name="ngay_sinh"/>
                            <field name="tuoi"/>
                            <field name="so_nguoi_bang_tuoi"/>
                            <field name="que_quan"/>
                            <field name="email"/>
                            <field name="anh" widget="image"/>
                        </group>
                        <notebook>
                            <page string="Danh sách lịch sử công tác">
                                <field name="lich_su_cong_tac_ids"/>
                            </page>
                            <page string="Danh sách chứng chỉ bằng cấp">
                                <field name="danh_sach_chung_chi_bang_cap_ids"/>
                            </page>
                            <page string="Lương &amp; Bảo hiểm">
                                <group col="2">
                                    <group string="Thông tin Lương (Lấy từ HĐ hiệu lực)">
                                        <field name="luong_co_ban" readonly="1"/>
                                        <field name="phu_cap" readonly="1"/>
                                    </group>
                                    <group string="Thông tin Bảo hiểm">
                                        <field name="he_so_bao_hiem" readonly="1"/>
                                        <field name="ty_le_bhxh"/>
                                        <field name="ty_le_bhyt"/>
                                        <field name="ty_le_bhtn"/>
                                        <field name="so_nguoi_phu_thuoc" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Người phụ thuộc">
                                <field name="phu_thuoc_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="ngay_sinh"/>
                                        <field name="moi_quan_he"/>
                                        <field name="ma_so_thue"/>
                                        <field name="trang_thai" widget="badge"
                                               decoration-muted="trang_thai == 'nhap'"
                                               decoration-success="trang_thai == 'hieu_luc'"
                                               decoration-danger="trang_thai == 'het_han'"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Hợp đồng Lao động">
                                <field name="hop_dong_ids" context="{'default_nhan_vien_id': active_id}">
                                    <tree>
                                        <field name="name"/>
                                        <field name="loai_hop_dong" widget="badge"
                                               decoration-info="loai_hop_dong == 'thu_viec'"
                                               decoration-success="loai_hop_dong == 'chinh_thuc'"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="luong_co_ban" sum="Tổng lương cơ bản"/>
                                        <field name="phu_cap" sum="Tổng phụ cấp"/>
                                        <field name="trang_thai" widget="badge"
                                               decoration-muted="trang_thai == 'nhap'"
                                               decoration-success="trang_thai == 'hieu_luc'"
                                               decoration-danger="trang_thai == 'het_han'"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_dinh_danh"/>
                    <field name="ho_ten_dem"/>
                    <field name="ten"/>
                    <field name="ho_va_ten"/>
                    <field name="ngay_sinh"/>
                    <field name="tuoi"/>
                    <field name="so_nguoi_bang_tuoi"/>
                    <field name="que_quan"/>
                    <field name="email"/>
                    <field name="luong_co_ban"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="nhan_vien_search">
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="ngay_sinh"/>
                    <field name="tuoi"/>
                    <field name="que_quan"/>
                    <field name="email"/>
                </search>
            </field>
        </record>

        <record id="view_nhan_vien_kanban" model="ir.ui.view">
            <field name="name">nhan_vien.kanban</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="id"/>
                    <field name="ho_va_ten"/>
                    <field name="email"/>
                    <field name="luong_co_ban"/>
                    <field name="ma_dinh_danh"/>
                    <field name="anh"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                <t t-if="record.anh.raw_value">
                                    <div class="o_kanban_image_fill_left d-none d-md-block"
                                         t-attf-style="background-image: url('#{kanban_image('nhan_vien', 'anh', record.id.raw_value)}')"/>
                                </t>
                                <t t-else="">
                                    <div class="o_kanban_image_fill_left o_kanban_image_placeholder"/>
                                </t>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title" style="font-size: 1.1em; color: #1e1b4b;">
                                        <field name="ho_va_ten"/>
                                    </strong>
                                    <div class="o_kanban_tags_section"/>
                                    <ul style="list-style-type: none; padding-left: 0; margin-top: 5px; color: #475569;">
                                        <li><strong>Mã:</strong> <field name="ma_dinh_danh"/></li>
                                        <li><strong>Email:</strong> <field name="email"/></li>
                                        <li><strong>Lương cơ bản:</strong> <field name="luong_co_ban"/> VND</li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref = "nhan_vien_search"/>
        </record>
    </data>
</odoo>
        
    